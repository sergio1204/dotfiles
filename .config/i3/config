# lock / logout / reboot / shutdown
bindsym $mod+l       exec --no-startup-id i3lock -i /home/sergey/Pictures/soty.png
bindsym $mod+Shift+l exec --no-startup-id i3-msg exit
bindsym $mod+Shift+k exec --no-startup-id systemctl reboot
bindsym $mod+Shift+m exec --no-startup-id systemctl poweroff

# apps binds
bindsym $mod+Return       exec --no-startup-id xterm
bindsym $mod+x            exec --no-startup-id xterm -e ranger
bindsym $mod+Shift+x      exec --no-startup-id pcmanfm-qt
bindsym $mod+c            exec --no-startup-id firefox
bindsym $mod+d            exec --no-startup-id quodlibet
bindsym $mod+Shift+d      exec --no-startup-id quodlibet --play-pause
bindsym $mod+Shift+Return exec --no-startup-id geany
bindsym $mod+v            exec --no-startup-id zenity --calendar

# printscreen
bindsym Print       --release exec --no-startup-id scrot -s ~/Pictures/`date +%Y-%m-%d_%H:%M:%S`.png
bindsym Shift+Print --release exec --no-startup-id scrot -d 1 ~/Pictures/`date +%Y-%m-%d_%H:%M:%S`.png

# picom
bindsym $mod+p       exec --no-startup-id picom &
bindsym $mod+Shift+p exec --no-startup-id killall picom

# dunst
bindsym $mod+u       exec --no-startup-id  dunstctl history-pop
bindsym $mod+Shift+u exec --no-startup-id  dunstctl close-all

# dmenu/rofi
#bindsym $mod+z       exec --no-startup-id dmenu_run -fn 'JetBrains Mono-10' -nb '#212134' -nf '$text-color' -sb '$bg-color' -l 10
bindsym $mod+z       exec --no-startup-id rofi -show drun
bindsym $mod+Shift+z exec --no-startup-id rofi -show run

# autostart
exec        --no-startup-id setxkbmap -layout us,ru -option grp:alt_shift_toggle &
exec        --no-startup-id feh --bg-scale /home/sergey/Pictures/borda2.jpg &
exec        --no-startup-id picom &
exec_always --no-startup-id $HOME/.config/polybar/launch.sh
