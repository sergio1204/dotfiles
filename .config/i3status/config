# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 1
        output_format = "i3bar"
}

#order += "ipv6"
order += "volume master"
order += "memory"
order += "cpu_usage"
order += "cpu_temperature 0"
#order += "wireless _first_"
#order += "ethernet _first_"
order += "battery all"
#order += "disk /"
#order += "load"
order += "tztime local"

wireless _first_ {
        format_up = " %quality"
        format_down = " down"
}

ethernet _first_ {
        format_up = " %speed"
        format_down = " down"
}

battery all {
        format = "%status %percentage"
        last_full_capacity = true
        status_chr = "⚡"
        status_bat = ""
        status_unk = "?"
        status_full = ""
        low_threshold = 10
        path = "/sys/class/power_supply/BAT%d/uevent"
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

memory {
        format = " %used"
        threshold_degraded = "10%"
        format_degraded = "%free"
}

tztime local {
        format = " %a %d  %H:%M:%S"
}

volume master {
        format = " %volume"
        format_muted = " %volume"
        device = "default"
	mixer = "Master"
	mixer_idx = 0
}

cpu_usage {
        format = " %usage"
}

cpu_temperature 0 {
        format = " %degrees"
        max_threshold = "80"
        format_above_threshold = " %degrees"
        path = "/sys/class/thermal/thermal_zone0/temp"
}
